# ==========================================
# Drasa AI - Environment Variables Template
# ==========================================
# Copy this file to '.env' or '.env.local' and fill in the values.

# ------------------------------------------
# 1. AI Provider Keys
# ------------------------------------------
# OpenRouter is used for Claude 3.5, GPT-4o, and Free Open-Source Models
OPENROUTER_API_KEY="sk-or-v1-..."

# Google Generative AI is used natively for Gemini 1.5 Pro and Flash
GOOGLE_GENERATIVE_AI_API_KEY="AIzaSy..."

# ------------------------------------------
# 2. Authentication (NextAuth / Auth.js)
# ------------------------------------------
# Generate a secret by running: `npx auth secret` or `openssl rand -base64 32`
NEXTAUTH_SECRET="your_nextauth_secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Credentials for Sign In
# Obtain from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ------------------------------------------
# 3. Database & Caching
# ------------------------------------------
# MongoDB Connection String (e.g., from MongoDB Atlas)
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/dbname"

# Redis Connection URL (e.g., from Upstash or Local)
REDIS_URL="redis://default:password@localhost:6379"

# ------------------------------------------
# 4. Payments (Razorpay)
# ------------------------------------------
# Obtain these from your Razorpay Dashboard (Use Test Keys for development!)
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
